generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum RequestType {
  SGK_GIRIS
  SGK_CIKIS
}

enum RequestStatus {
  BEKLEYEN
  ONAYLANDI
  REDDEDILDI
  IPTAL
}

enum SmsVerificationType {
  register
  login
  forgot_password
}

model Tenant {
  id                  String           @id @default(cuid())
  firmaKodu           String           @unique
  firmaUnvani         String?
  vergiNo             String?
  sektor              String?
  calisanSayisi       Int?
  subeSayisi          Int?
  il                  String?
  ilce                String?
  mahalle             String?
  adres               String?
  postaKodu           String?
  telefon             String?
  ePosta              String?
  webSitesi           String?
  onboardingCompleted Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  deletedAt           DateTime?
  users               User[]
  branches            Branch[]
  departments         Department[]
  employees           Employee[]
  restrictedEmployees RestrictedEmployee[]
  requests            Request[]
  payrollEntries      PayrollEntry[]
  puantajLocks        PuantajLock[]
  documents           Document[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  onboardingSteps     OnboardingStep[]
  smsVerifications    SmsVerification[]
  units               Unit[]
}

model User {
  id            String          @id @default(cuid())
  tenantId      String
  adSoyad       String
  tckn          String
  eposta        String
  telefon       String
  sifreHash     String
  status        UserStatus      @default(ACTIVE)
  lastLoginAt   DateTime?
  isAnaKullanici Boolean        @default(false)
  preferences   Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  userRoles     UserRole[]
  approvals     RequestApproval[]
  notifications Notification[]
  auditLogs     AuditLog[]
  yetkiliDepartments Department[] @relation("DepartmentYetkili")
  smsVerifications SmsVerification[]

  @@unique([tenantId, tckn])
  @@unique([tenantId, eposta])
}

model SmsVerification {
  id        String               @id @default(cuid())
  tenantId  String?
  userId    String?
  telefon   String
  type      SmsVerificationType
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int                  @default(0)
  payload   Json?
  createdAt DateTime             @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, telefon, type, createdAt])
  @@index([tenantId, userId, type, createdAt])
}

model Role {
  id              String           @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, name])
}

model Permission {
  id              String           @id @default(cuid())
  resource        String
  action          String
  scope           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@unique([resource, action, scope])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model RolePermission {
  id           String      @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  role         Role        @relation(fields: [roleId], references: [id])
  permission   Permission  @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model Branch {
  id         String       @id @default(cuid())
  tenantId   String
  name       String
  subeTuru   String?
  acilisTarihi DateTime?
  vergiNo    String?
  vergiDairesi String?
  sgkSicilNo String?
  il         String?
  ilce       String?
  mahalle    String?
  adres      String?
  postaKodu  String?
  telefon    String?
  ePosta     String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?
  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  departments Department[]
  employees  Employee[]

  @@unique([tenantId, name])
}

model Department {
  id            String      @id @default(cuid())
  tenantId      String
  branchId      String
  name          String
  masrafKodu    String?
  acilisTarihi  DateTime?
  yetkiliUserId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  branch        Branch      @relation(fields: [branchId], references: [id])
  yetkiliUser   User?       @relation("DepartmentYetkili", fields: [yetkiliUserId], references: [id])
  employees     Employee[]
  units         Unit[]

  @@unique([tenantId, branchId, name])
}

model Unit {
  id           String      @id @default(cuid())
  tenantId     String
  departmentId String
  name         String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  department   Department  @relation(fields: [departmentId], references: [id])

  @@unique([tenantId, departmentId, name])
}

model Employee {
  id                String      @id @default(cuid())
  tenantId          String
  branchId          String?
  departmentId      String?
  tckn              String
  adSoyad           String
  unvan             String?
  sicil             String?
  statu             String?
  org               String?
  personelJson      Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?
  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  branch            Branch?     @relation(fields: [branchId], references: [id])
  department        Department? @relation(fields: [departmentId], references: [id])
  requests          Request[]

  @@unique([tenantId, tckn])
}

model RestrictedEmployee {
  id              String    @id @default(cuid())
  tenantId        String
  employeeId      String?
  adSoyad         String
  tckn            String
  neden           String
  aciklama        String?
  durum           String
  eklenmeTarihi   DateTime
  kaldirilmaTarihi DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, tckn])
}

model Request {
  id              String            @id @default(cuid())
  tenantId        String
  employeeId      String?
  type            RequestType
  status          RequestStatus     @default(BEKLEYEN)
  payload         Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  employee        Employee?         @relation(fields: [employeeId], references: [id])
  approvals       RequestApproval[]
}

model RequestApproval {
  id         String   @id @default(cuid())
  requestId  String
  userId     String
  status     String
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  request    Request  @relation(fields: [requestId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model OnboardingStep {
  id         String   @id @default(cuid())
  tenantId   String
  key        String
  completed  Boolean  @default(false)
  payload    Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
}

model PayrollEntry {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  year       Int
  month      Int
  payload    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, employeeId, year, month])
}

model Document {
  id          String         @id @default(cuid())
  tenantId    String
  uploadedBy  String?
  bucket      String?
  path        String
  mimeType    String
  size        Int
  originalName String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  links       DocumentLink[]
}

model DocumentLink {
  id          String   @id @default(cuid())
  documentId  String
  entityType  String
  entityId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  document    Document @relation(fields: [documentId], references: [id])
}

model Notification {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  title      String
  body       String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String?
  meta       Json?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model PuantajLock {
  id        String   @id @default(cuid())
  tenantId  String
  year      Int
  month     Int
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, year, month])
}
